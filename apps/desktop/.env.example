# DBX Studio Environment Configuration
# Copy this file to .env.local and fill in the values

# ===========================================
# API Configuration
# ===========================================
VITE_API_URL=http://localhost:3001

# Main Server API (Backend for AWS Cognito authentication and AI features)
VITE_MAIN_SERVER_URL=http://localhost:8000

# ===========================================
# AWS Cognito Configuration
# IMPORTANT: Get actual values from ENV_CREDENTIALS.txt in project root
# ===========================================
VITE_COGNITO_USER_POOL_ID=your-user-pool-id
VITE_COGNITO_CLIENT_ID=your-client-id
VITE_COGNITO_REGION=us-east-1

# ===========================================
# Firebase Configuration (Legacy - Optional)
# ===========================================
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ===========================================
# Application Settings
# ===========================================
VITE_APP_NAME=DBX Studio
VITE_APP_VERSION=1.0.0
